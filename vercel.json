{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "docs/**": false,
      "feature/**": false,
      "fix/**": false,
      "chore/**": false,
      "ai/**": false,
      "dependabot/**": false,
      "renovate/**": false
    }
  },
  "ignoreCommand": "if [ \"$VERCEL_GIT_COMMIT_REF\" = \"main\" ]; then exit 1; else exit 0; fi"
}

# HTTP server
PORT=8787
MCP_PATH=/mcp
PUBLIC_BASE_URL=https://ds-mcp-server-one.vercel.app

# Runtime/dev environment.
DS_MCP_APP_RUNTIME_MODE=local
DS_MCP_SUPABASE_ACTIVE_DB_TARGET=default
DS_MCP_DEV_TOOLS_ENABLED=false
DS_MCP_DEV_TOOLS_ALLOW_REAL_DB_SWITCH=false
# When enabled, the localhost admin UI at /admin can switch the active runtime and DB target,
# including guarded production profiles.

# Optional bearer auth for MCP calls.
# Leave empty for local prototype only. Set before exposing publicly.
DS_MCP_MCP_BEARER_TOKEN=

# Optional legacy capability URL secret for ChatGPT MCP connector.
# Prefer OAuth; use only for temporary compatibility with No Authentication.
DS_MCP_MCP_URL_SECRET=

# Optional bearer auth for REST API calls.
# If set, all /api/* routes except /api/capabilities, /api/diagnostics/url-map, and /api/webhooks/github require Authorization: Bearer <token>.
DS_MCP_REST_API_BEARER_TOKEN=

# Security hardening.
# strict = fail closed in production for sensitive routes and enforce allowlisted CORS when browser origins are configured.
# relaxed = prototype mode with local fallback behavior.
SECURITY_ENFORCEMENT=strict
CORS_ALLOWED_ORIGINS=https://chatgpt.com,https://chat.openai.com
MAX_JSON_BODY_BYTES=1048576
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

# Supabase persistence for AgentOps tasks/workflow.
DS_MCP_SUPABASE_URL=
DS_MCP_SUPABASE_SERVICE_ROLE_KEY=

# Admin Supabase OAuth. Strict production startup requires URL, anon key, and provider.
DS_MCP_SUPABASE_ANON_KEY=
DS_MCP_SUPABASE_OAUTH_PROVIDER=google
DS_MCP_SUPABASE_OAUTH_SCOPES=openid,email,profile
DS_MCP_SUPABASE_ADMIN_ALLOWED_EMAILS=

# Optional named Supabase DB profiles for dev tools switching.
DS_MCP_SUPABASE_REAL_URL=
DS_MCP_SUPABASE_REAL_SERVICE_ROLE_KEY=
DS_MCP_SUPABASE_LOCAL_URL=
DS_MCP_SUPABASE_LOCAL_SERVICE_ROLE_KEY=
DS_MCP_SUPABASE_DEVELOPMENT_URL=
DS_MCP_SUPABASE_DEVELOPMENT_SERVICE_ROLE_KEY=
DS_MCP_SUPABASE_STAGING_URL=
DS_MCP_SUPABASE_STAGING_SERVICE_ROLE_KEY=
DS_MCP_SUPABASE_PRODUCTION_URL=
DS_MCP_SUPABASE_PRODUCTION_SERVICE_ROLE_KEY=

# Optional backend integration for write tools.
DS_MCP_DS_BACKEND_URL=http://localhost:3000
DS_MCP_INTERNAL_AGENT_RESULT_TOKEN=change-me

# ChatGPT Workspace Agent trigger.
DS_MCP_WORKSPACE_AGENT_TRIGGER_ID=
DS_MCP_WORKSPACE_AGENT_API_BASE_URL=https://api.chatgpt.com

# GitHub gateway.
# Use a fine-grained PAT or GitHub App installation token with least privilege.
# Minimum suggested repo permissions for MVP: Contents read/write, Pull requests read/write, Actions read.
DS_MCP_GITHUB_TOKEN=
# Optional. If unset, the GitHub webhook route stays disabled.
DS_MCP_GITHUB_WEBHOOK_SECRET=
DS_MCP_GITHUB_ALLOWED_REPOS=dw18031988/ds_mcp_server,nhatnguyenquang1838-coder/rental_home,nhatnguyenquang1838-coder/gwc
DS_MCP_GITHUB_DEFAULT_BASE_BRANCH=main
DS_MCP_GITHUB_ALLOWED_BRANCH_PREFIXES=feature/,fix/,chore/,docs/,ai/
DS_MCP_GITHUB_MAX_FILE_BYTES=1048576

# DS upload gateway MVP.
DS_MCP_DS_UPLOAD_SESSION_TTL_SECONDS=3600
DS_MCP_DS_UPLOAD_CHUNK_MAX_BYTES=1048576
DS_MCP_DS_UPLOAD_MAX_FILE_BYTES=10485760
DS_MCP_DS_UPLOAD_STORAGE=memory

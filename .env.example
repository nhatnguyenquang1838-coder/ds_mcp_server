# HTTP server
PORT=8787
MCP_PATH=/mcp

# Optional bearer auth for MCP calls.
# Leave empty for local prototype only. Set before exposing publicly.
MCP_BEARER_TOKEN=

# Optional bearer auth for REST API calls.
# If set, all /api/* routes except /api/capabilities require Authorization: Bearer <token>.
REST_API_BEARER_TOKEN=

# Optional backend integration for write tools.
DS_BACKEND_URL=http://localhost:3000
INTERNAL_AGENT_RESULT_TOKEN=change-me

# GitHub gateway.
# Use a fine-grained PAT or GitHub App installation token with least privilege.
# Minimum suggested repo permissions for MVP: Contents read/write, Pull requests read/write, Actions read.
GITHUB_TOKEN=
GITHUB_ALLOWED_REPOS=nhatnguyenquang1838-coder/ds_mcp_server,nhatnguyenquang1838-coder/rental_home
GITHUB_DEFAULT_BASE_BRANCH=main
GITHUB_ALLOWED_BRANCH_PREFIXES=feature/,fix/,chore/,docs/,ai/
GITHUB_MAX_FILE_BYTES=256000

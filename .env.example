# HTTP server
PORT=8787
MCP_PATH=/mcp
PUBLIC_BASE_URL=https://ds-mcp-server-theta.vercel.app

# Runtime/dev environment.
APP_RUNTIME_MODE=local
SUPABASE_ACTIVE_DB_TARGET=default
DEV_TOOLS_ENABLED=false
DEV_TOOLS_ALLOW_REAL_DB_SWITCH=false

# Optional bearer auth for MCP calls.
# Leave empty for local prototype only. Set before exposing publicly.
MCP_BEARER_TOKEN=

# Optional bearer auth for REST API calls.
# If set, all /api/* routes except /api/capabilities require Authorization: Bearer <token>.
REST_API_BEARER_TOKEN=

# Supabase persistence for AgentOps tasks/workflow.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional named Supabase DB profiles for dev tools switching.
SUPABASE_REAL_URL=
SUPABASE_REAL_SERVICE_ROLE_KEY=
SUPABASE_LOCAL_URL=
SUPABASE_LOCAL_SERVICE_ROLE_KEY=
SUPABASE_DEVELOPMENT_URL=
SUPABASE_DEVELOPMENT_SERVICE_ROLE_KEY=
SUPABASE_STAGING_URL=
SUPABASE_STAGING_SERVICE_ROLE_KEY=
SUPABASE_PRODUCTION_URL=
SUPABASE_PRODUCTION_SERVICE_ROLE_KEY=

# Optional backend integration for write tools.
DS_BACKEND_URL=http://localhost:3000
INTERNAL_AGENT_RESULT_TOKEN=change-me

# ChatGPT Workspace Agent trigger.
WORKSPACE_AGENT_TRIGGER_ID=
WORKSPACE_AGENT_API_BASE_URL=https://api.chatgpt.com

# GitHub gateway.
# Use a fine-grained PAT or GitHub App installation token with least privilege.
# Minimum suggested repo permissions for MVP: Contents read/write, Pull requests read/write, Actions read.
GITHUB_TOKEN=
GITHUB_ALLOWED_REPOS=nhatnguyenquang1838-coder/ds_mcp_server,nhatnguyenquang1838-coder/rental_home
GITHUB_DEFAULT_BASE_BRANCH=main
GITHUB_ALLOWED_BRANCH_PREFIXES=feature/,fix/,chore/,docs/,ai/
GITHUB_MAX_FILE_BYTES=1048576

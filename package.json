{
  "name": "ds-mcp-server",
  "version": "0.1.0",
  "description": "Self-hosted MCP server for Design System / ChatGPT connector workflows.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test test/*.test.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.49.1",
    "xstate": "^5.19.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "axios": "^1.18.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
